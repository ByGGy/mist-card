{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "allowImportingTsExtensions": true,
    "noEmit": true,
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}